---
---

<div id="preloader" class="fixed inset-0 z-[9999] flex flex-col items-center justify-center bg-[#0891b2] dark:bg-[#164e63] overflow-hidden">
  <div id="preloader-text" class="flex flex-col items-center gap-3" style="opacity: 0; transform: translateY(20px);">
    <div class="text-white text-6xl font-bold tracking-widest font-['Poppins']">
      FM
    </div>
    <div id="preloader-bar" class="h-[2px] w-0 bg-white/60 rounded-full"></div>
  </div>
</div>

<script>
  import gsap from 'gsap';

  const tl = gsap.timeline();

  tl
    .to('#preloader-text', {
      opacity: 1,
      y: 0,
      duration: 0.5,
      ease: 'power2.out',
    })
    .to('#preloader-bar', {
      width: '64px',
      duration: 0.6,
      ease: 'power2.inOut',
    })
    .to('#preloader-text', {
      opacity: 0,
      y: -10,
      duration: 0.35,
      delay: 0.3,
      ease: 'power2.in',
    })
    .to('#preloader', {
      yPercent: -100,
      duration: 0.75,
      ease: 'power3.inOut',
      onComplete: () => {
        document.getElementById('preloader')?.remove();
      },
    });
</script>
